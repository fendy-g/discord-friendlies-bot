CREATE TABLE player (
    playerId varchar(20) NOT NULL,
    serverId varchar(20) NOT NULL,
    playerName varchar(40),
    PRIMARY KEY (playerId, serverId)
);

CREATE TABLE season (
    id serial PRIMARY KEY,
    serverId varchar(20) NOT NULL,
    seasonName varchar(40) NOT NULL,
    activeSeason boolean,
    startDate date,
    endDate date
);

// Basically the "weekly" or whatever occurence you run each round for
CREATE TABLE seasonSet (
    id serial PRIMARY KEY,
    serverId varchar(20) NOT NULL,
    seasonId serial NOT NULL,
    setName varchar NOT NULL,
    activeSet boolean, 
    CONSTRAINT fk_season FOREIGN KEY (seasonId) REFERENCES season(id)
    CONSTRAINT UNIQUE (seasonId, setName)
);

CREATE TABLE matchRecord (
    id serial PRIMARY KEY,
    serverId varchar(20) NOT NULL,
    seasonSetId serial NOT NULL,
    player varchar(20) NOT NULL,
    opponent varchar(20) NOT NULL,
    winner varchar(20),
    wins int,
    losses int,
    CONSTRAINT fk_season FOREIGN KEY (seasonSetId) REFERENCES seasonSet(id),
    CONSTRAINT fk_player FOREIGN KEY (serverId, player) REFERENCES player(serverId, playerId),
    CONSTRAINT fk_opponent FOREIGN KEY (serverId, opponent) REFERENCES player(serverId, playerId),
    CONSTRAINT fk_winner FOREIGN KEY (serverId, winner) REFERENCES player(serverId, playerId)
);